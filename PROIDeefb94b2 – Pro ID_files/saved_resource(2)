jQuery(document).ready(function($) {
    $('#download-permalinks').hide();
    $('#user-genarated-done').hide();
  $('#users-genarate-form').on('submit', function(e) {
    $('#create_new_user_btn').val('Creating...');
    e.preventDefault();
    
    var formData = $(this).serializeArray();
    var numUsers = $('#num_of_users').val();
    var batchSize = 50; // Number of users to create in each batch
    var totalBatches = Math.ceil(numUsers / batchSize); // 11
    var currentBatch = 1;
    var permalinks = [];
    var lastroundbatch = numUsers % batchSize;

    //create loop to create users
    while (currentBatch <= totalBatches) {
    createUsers();
      currentBatch++;
    }

    async function createUsers() {
      if(currentBatch === totalBatches){
        currentBatchSize = lastroundbatch;
      }else{
        currentBatchSize = batchSize;
      }

      $.ajax({
        url: ajaxurl, // WordPress AJAX handler
        method: 'POST',
        async: true,
        data: {
            action: 'create_user_batch',
            currentBatchSize: currentBatchSize,
            form_data: formData
        },
        dataType: 'json',
        beforeSend: function() {
          // Show loading indicator or disable submit button
        },
        success: function(response) {
          // Process the response (e.g., handle errors, update UI)
          //array push permalinks
          permalinks.push(response.permalinks);
          if (permalinks.length === totalBatches) {
            downloadPermalinks(permalinks);
            $('#create_new_user_btn').val('Create New User');
          }
        },
        error: function(xhr, status, error) {
          // Handle error (e.g., show error message)
        },
        complete: function() {
          // Hide loading indicator or enable submit button
        }
      });
    }

    function downloadPermalinks(permalinks) {
        
      $.ajax({
        url: ajaxurl, 
        method: 'POST',
        data: {
          action: 'create_user_download_permalinks',
          permalinks: permalinks
        },
        beforeSend: function() {
          // Show loading indicator or disable UI
        },
        success: function(response) {
            $('#download-permalinks').show();
			 $('#user-genarated-done').show();
            $('#download-permalinks').attr('href', response.download_url);
        },
        error: function(xhr, status, error) {
          // Handle error (e.g., show error message)
        },
        complete: function() {
          // Hide loading indicator or enable UI
        }
      });
    }
  });
});


jQuery(document).ready(function ($) {
	console.log('test');
    // Get the tab options data
    const tabOptions = customScriptData.tabOptions;

    // Define the tab options and their corresponding CSS IDs
    const tabMappings = [
        { option: 'home', cssID: 'home_tab' },
        { option: 'info', cssID: 'info_tab' },
        { option: 'photo', cssID: 'photo_tab' },
        { option: 'video', cssID: 'video_tab' },
        { option: 'shop', cssID: 'shop_tab' },
        { option: 'blog', cssID: 'blog_tab' },
    ];
    if (tabOptions.length === 0) {
        // If no checkboxes are checked, show all elements
        tabMappings.forEach(({ cssID }) => {
            $(`#${cssID}`).show();
        });
    } else {
        // Loop through the tabMappings and hide the elements if their corresponding option is unchecked
        tabMappings.forEach(({ option, cssID }) => {
            if (!tabOptions.includes(option)) {
                $(`#${cssID}`).hide();
            } else {
                $(`#${cssID}`).show();
            }
        });
    }
});


