document.addEventListener('DOMContentLoaded', function () {
    const button = document.querySelector('.test_btn');
    if (!button) return;

    // Function to detect the browser
    function detectBrowser() {
        const userAgent = navigator.userAgent.toLowerCase();

        // Check for Google Chrome
        const isChrome = /chrome/.test(userAgent) && !/edge|edg/.test(userAgent) && !/opr/.test(userAgent);

        // Check for Safari
        const isSafari = /safari/.test(userAgent) && !/chrome/.test(userAgent);

        // Check for Samsung Browser
        const isSamsung = /samsungbrowser/.test(userAgent);

        return isChrome || isSafari || isSamsung;
    }

    // Attach event listener to the button
    button.addEventListener('click', function () {
        if (!detectBrowser()) {
            alert('Vui lòng mở bằng trình duyệt ngoài để lưu liên hệ');
        }
    });
});


