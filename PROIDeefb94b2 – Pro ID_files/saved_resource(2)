jQuery( 'body' ).on( 'click', '.proid-delete-profile-btn a', function( e ) {
	e.preventDefault();
	
	var $ = jQuery;

	if ( $(this).hasClass('ajaxing') ) {
		return;
	}

	if ( confirm( 'Are you sure you want to delete this post?' ) ) {
		$( this ).addClass('ajaxing');
		$.ajax({
			url: exad_frontend_ajax_object.ajaxurl,
			type: 'POST',
			dataType: 'JSON',
			data: {
				action: 'proid_delete_post',
				post_id: $(this).closest('.jet-listing-grid__item').attr('data-post-id'),
			},
			success: function( d ) {
				$('.jet-listing-grid__item[data-post-id="' + d.id + '"]').remove();
			}
		})
		.fail(function() {
			alert( 'Unable to delete.' );
		})
		.always(function() {
			
		});
		
	}

} );

